{
    "version": 2,
    "functions": {
        "api/*.js": {
            "memory": 256,
            "maxDuration": 10
        }
    },
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": { "distDir": "dist" }
        }
    ],
    "rewrites": [{ "source": "/api/:path*", "destination": "/api/:path*" }]
}
